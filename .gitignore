# Spec Kit generated integration manifest (timestamp churn, not meaningful to track)
.specify/integrations/claude.manifest.json

# JetBrains IDE project files
.idea/

# Hermes agent runtime (local plans, settings, skills — machine-specific)
.hermes/

# Node
node_modules/
.pnpm-store/
# Playwright E2E artifacts
test-results/
playwright-report/

# Rails
backend/tmp/
backend/log/

# Claude Code runtime
.claude/scheduled_tasks.lock

# Self-hosted geo data — generated from public OSM extracts by infra/scripts/*.
# Large (GBs) and fully rebuildable; never commit. The scripts/config are tracked.
infra/data/
infra/routing/data/
infra/tiles/data/
# Camera GeoJSON filtered from the OSM extract (build-cameras.sh) and delivered
# to the backend's read path — generated, rebuildable; never commit.
backend/storage/cameras.geojson

# Test coverage reports (SimpleCov)
backend/coverage/

# Kamal real secrets — never commit (the .example template is tracked)
backend/.kamal/secrets
backend/.kamal/secrets.*
!backend/.kamal/secrets.example

# Kamal real deploy config — never commit (the .example template is tracked).
# Copy config/deploy.example.yml to config/deploy.yml and edit your real values there.
backend/config/deploy.yml

# Rails master key and any per-environment credential keys — never commit
backend/config/master.key
backend/config/credentials/*.key

# Geo build manifest/output (produced by infra/scripts/build-geo.sh in CI)
infra/build/

# Per-developer region config (generated by infra/scripts/setup.sh)
infra/.region

# Per-developer geocoder env (generated by infra/scripts/setup.sh): selects the
# backend's country vs single-state mode + viewbox. Absent → country US default.
infra/.env

# OS & editor cruft (repo-wide; frontend/ has its own copy of these). macOS
# scatters .DS_Store into every browsed folder, and editors leave swap/backup files.
.DS_Store
*.swp
*.swo
*~
.vscode/
!.vscode/extensions.json
