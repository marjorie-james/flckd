# Frontend / Caddy edge config (gitignored real values; this .example is tracked).
#
#   cp backend/.kamal/frontend.env.example backend/.kamal/frontend.env   # then edit
#
# Read by infra/scripts/deploy-frontend.sh and passed into the Caddy container.

# Apex domain the frontend is served on. Caddy serves this + www.<domain> (www
# redirects to apex) and auto-provisions Let's Encrypt TLS for both.
FLCKD_DOMAIN=flckd.example

# Let's Encrypt contact (expiry notices). Required by Caddy's ACME.
ACME_EMAIL=you@example.com

# Host header kamal-proxy routes the backend on. Defaults to deploy.yml's
# proxy.host; only set this if you change that.
# API_HOST=api.flckd.example
