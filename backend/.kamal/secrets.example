# Kamal secrets template. Copy to `.kamal/secrets` (gitignored) and fill in, or
# better: reference your shell env / a password manager so plaintext never lands
# on disk. Kamal reads this at deploy time and injects the `secret:` entries
# referenced in config/deploy.yml.
#
#   cp .kamal/secrets.example .kamal/secrets   # then edit

# --- Image registry (registry: in deploy.yml) ---
KAMAL_REGISTRY_USERNAME=$KAMAL_REGISTRY_USERNAME
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# --- Rails app (env.secret in deploy.yml) ---
# The app's credentials key. Prefer reading the file over pasting the value:
RAILS_MASTER_KEY=$(cat config/master.key)

# App's DB password. MUST equal POSTGRES_PASSWORD below (same database).
DATABASE_PASSWORD=$DATABASE_PASSWORD

# --- Postgres accessory ---
POSTGRES_PASSWORD=$DATABASE_PASSWORD

# --- Nominatim geocoder accessory ---
NOMINATIM_PASSWORD=$NOMINATIM_PASSWORD
