# Kamal secrets template. Copy to `.kamal/secrets` (gitignored) and fill in, or
# better: reference your shell env / a password manager so plaintext never lands
# on disk. Kamal reads this at deploy time and injects the `secret:` entries
# referenced in config/deploy.yml.
#
#   cp .kamal/secrets.example .kamal/secrets   # then edit

# --- Deploy host (kept OUT of git) ---
# The single-host IP is NOT hardcoded in deploy.yml; it is referenced there as
#   host: <%= ENV.fetch("FLCKD_HOST") %>
# Export the real value in .kamal/secrets.env (gitignored, sourced by
# bin/kamal-docker, forwarded as -e FLCKD_HOST). The helper scripts read the same
# value from secrets.env via lib-deploy-host.sh. It is NOT a container secret, so
# it does not belong in this file's secret: list — shown here only for discovery.
#   .kamal/secrets.env:  export FLCKD_HOST=203.0.113.5

# --- Image registry (registry: in deploy.yml) ---
KAMAL_REGISTRY_USERNAME=$KAMAL_REGISTRY_USERNAME
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# --- Rails app (env.secret in deploy.yml) ---
# The app's credentials key. Prefer reading the file over pasting the value:
RAILS_MASTER_KEY=$(cat config/master.key)

# Production secret_key_base. Rails reads ENV["SECRET_KEY_BASE"] in production
# (it takes precedence over credentials), so this is the app's signing secret.
# Generated once and persisted by `bin/kamal-docker` (first kamal run mints it
# into .kamal/secrets.env, later runs reuse it) — generation is part of setup.
SECRET_KEY_BASE=$SECRET_KEY_BASE

# App's DB password. MUST equal POSTGRES_PASSWORD below (same database).
DATABASE_PASSWORD=$DATABASE_PASSWORD

# --- Postgres accessory ---
POSTGRES_PASSWORD=$DATABASE_PASSWORD

# --- Nominatim geocoder accessory ---
NOMINATIM_PASSWORD=$NOMINATIM_PASSWORD

# --- Single-state map framing + geocoding scope (not actually secret) ---
# Resolved by bin/kamal-docker from the deploy scope (backend/.kamal/geo.env) into
# .kamal/deploy-scope.env (gitignored, written before every kamal run). Read here
# with sed so Kamal injects them as the matching env.secret entries in deploy.yml.
# Both are empty for a whole-country deploy → the app frames the entire country.
GEOCODER_REGION_STATE=$(sed -n 's/^GEOCODER_REGION_STATE=//p' .kamal/deploy-scope.env 2>/dev/null | tr -d '\n')
GEOCODER_VIEWBOX=$(sed -n 's/^GEOCODER_VIEWBOX=//p' .kamal/deploy-scope.env 2>/dev/null | tr -d '\n')
