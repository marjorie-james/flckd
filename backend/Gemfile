source "https://rubygems.org"

# Bundle edge Rails instead: gem "rails", github: "rails/rails", branch: "main"
gem "rails", "~> 8.1.3"
# The modern asset pipeline for Rails [https://github.com/rails/propshaft]
gem "propshaft"
# Use postgresql as the database for Active Record
gem "pg", "~> 1.1"
# Use the Puma web server [https://github.com/puma/puma]
gem "puma", ">= 5.0"

# Use the solid adapters [https://github.com/rails/solid_cache, https://github.com/rails/solid_queue]
gem "solid_cache"
gem "solid_queue"
gem "solid_cable"

# Add HTTP asset caching/compression and X-Sendfile acceleration to Puma [https://github.com/basecamp/thruster/]
gem "thruster", require: false

# Windows does not include zoneinfo files, so bundle the tzinfo-data gem
gem "tzinfo-data", platforms: %i[ windows jruby ]

# --- Camera-Avoiding Route Planner: project dependencies ---
# Spatial: PostGIS-backed geometry types and spatial queries
gem "activerecord-postgis-adapter"
gem "rgeo"
gem "rgeo-activerecord"
gem "rgeo-geojson"
# Internationalization defaults (locale data for many languages)
gem "rails-i18n"
# Rate limiting / request throttling (anonymity hardening)
gem "rack-attack"
# Internal HTTP client to self-hosted geo services (routing/geocoding)
gem "faraday"
# Persistent/keep-alive HTTP connections — reused across the hundreds of tiled
# Overpass requests in a nationwide refresh to avoid per-request TCP handshakes.
gem "faraday-net_http_persistent"
# CORS for the SPA (same-origin in prod; configurable in dev)
gem "rack-cors"

group :development, :test do
  # See https://guides.rubyonrails.org/debugging_rails_applications.html#debugging-with-the-debug-gem
  gem "debug", platforms: %i[ mri windows ], require: "debug/prelude"

  # Static analysis for security vulnerabilities [https://brakemanscanner.org/]
  gem "brakeman", require: false

  # Audit the dependency graph against the Ruby advisory DB (bin/bundler-audit;
  # config in config/bundler-audit.yml). Run in CI alongside Brakeman.
  gem "bundler-audit", require: false

  # Omakase Ruby styling [https://github.com/rails/rubocop-rails-omakase]
  gem "rubocop-rails-omakase", require: false

  # Test framework
  gem "rspec-rails"
  gem "factory_bot_rails"
end

group :test do
  gem "simplecov", require: false
  # Stub external HTTP (e.g. Overpass) with recorded fixtures so the suite is
  # deterministic and never touches the network (Constitution Principle II).
  gem "webmock", require: false
end
