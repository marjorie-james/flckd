#!/usr/bin/env bash
# Run Kamal 2 from its official Docker image.
#
# Why: this project's host Ruby toolchain isn't used for app tooling, so rather
# than `gem install kamal` we run Kamal's published image. It needs four things
# from the host, all wired below:
#   - the repo (build context + config)        -> bind /workdir
#   - the Docker daemon (build & push image)    -> bind /var/run/docker.sock
#   - the SSH agent (reach deploy@<host>)       -> Docker Desktop ssh-auth socket
#   - known_hosts (host-key verification)       -> bind ~/.ssh/known_hosts (ro)
#
# Deploy secrets are loaded from .kamal/secrets.env (gitignored) and forwarded
# into the container; .kamal/secrets references them as $VARs.
#
# Usage (from anywhere): backend/bin/kamal-docker <kamal subcommand> [args]
#   e.g.  backend/bin/kamal-docker config
#         backend/bin/kamal-docker setup
#         backend/bin/kamal-docker deploy
set -euo pipefail

# Resolve paths (this script lives in backend/bin/).
BACKEND_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REPO_ROOT="$(cd "$BACKEND_DIR/.." && pwd)"   # Kamal reads git history for the image version
cd "$BACKEND_DIR"

# Load real secret values into the environment (.kamal/secrets reads these).
# Report a clear error instead of a cryptic `set -e` abort if the file fails to
# load (e.g. a future `$(cat …)` line referencing a missing file).
if [ -f .kamal/secrets.env ]; then
  set -a
  . .kamal/secrets.env || { echo "kamal-docker: failed to load .kamal/secrets.env" >&2; exit 1; }
  set +a
fi

# Ensure a stable production SECRET_KEY_BASE exists. Rails reads
# ENV["SECRET_KEY_BASE"] in production with precedence over the encrypted
# credentials, so this is the app's signing secret. Generation is part of setup:
# the first kamal run mints it and persists it into .kamal/secrets.env (gitignored);
# later runs reuse the persisted value so the secret is stable across deploys.
# CI supplies its own SECRET_KEY_BASE via the environment, in which case this is a
# no-op. We never rotate an existing value.
# Key the decision on whether the file already DECLARES the secret, not just on
# the sourced env var: that way an externally-exported value is captured into the
# file (rather than later replaced by a freshly minted one, which would silently
# rotate the production signing secret), and a repeat run can never append a
# duplicate line.
if [ -f .kamal/secrets.env ] \
   && ! grep -qE '^[[:space:]]*(export[[:space:]]+)?SECRET_KEY_BASE=' .kamal/secrets.env; then
  : "${SECRET_KEY_BASE:=$(openssl rand -hex 64)}"
  export SECRET_KEY_BASE
  printf '\n# Generated by kamal-docker — Rails production secret_key_base (stable, do not rotate).\nexport SECRET_KEY_BASE=%s\n' "$SECRET_KEY_BASE" >> .kamal/secrets.env
  echo "kamal-docker: persisted a stable SECRET_KEY_BASE in .kamal/secrets.env" >&2
elif [ -z "${SECRET_KEY_BASE:-}" ] && [ ! -f .kamal/secrets.env ]; then
  echo "kamal-docker: SECRET_KEY_BASE is unset and there is no .kamal/secrets.env to persist it into." >&2
  echo "kamal-docker: export SECRET_KEY_BASE in the environment, or create .kamal/secrets.env first." >&2
  exit 1
fi

# Derive the single-state backend env (GEOCODER_REGION_STATE + GEOCODER_VIEWBOX)
# from the deploy scope (the same .kamal/geo.env that drives geo provisioning) and
# write it to .kamal/deploy-scope.env (gitignored). Kamal reads that file via
# .kamal/secrets at deploy time, so a single-state production deploy frames the map
# on — and geocodes within — that state instead of the whole country (FR-007); both
# values are empty for a whole-country deploy. Written before EVERY kamal run so
# `config`, `setup`, and `deploy` all reflect the current scope. Values are written
# unquoted (the file is parsed by .kamal/secrets with sed, never sourced), which
# keeps spaces/commas intact.
# shellcheck source=/dev/null
. "$REPO_ROOT/infra/scripts/deploy-scope-env.sh"
{
  printf 'GEOCODER_REGION_STATE=%s\n' "${GEOCODER_REGION_STATE:-}"
  printf 'GEOCODER_VIEWBOX=%s\n' "${GEOCODER_VIEWBOX:-}"
} > "$BACKEND_DIR/.kamal/deploy-scope.env"

# Kamal 2.11.0, pinned by digest (the registry publishes :latest, not :2.11.0).
KAMAL_IMAGE="ghcr.io/basecamp/kamal@sha256:b0fb3d6e581da6a24d530b07a7daa6f5cf9046b3e51098a992f4f715c7f37270"

# Allocate a TTY only when attached to one, so background / CI / piped runs
# (e.g. `kamal-docker setup` in the background) don't abort with
# "the input device is not a TTY". (Plain string — macOS ships bash 3.2.)
TTY_FLAG=""
if [ -t 0 ] && [ -t 1 ]; then TTY_FLAG="-t"; fi

# Ensure known_hosts is a FILE before bind-mounting it: a missing path would be
# bind-mounted as an empty directory, silently breaking SSH host-key verification.
mkdir -p "$HOME/.ssh" && touch "$HOME/.ssh/known_hosts"

# SSH agent socket to forward into the container. Defaults to Docker Desktop's
# magic path; on a Linux daemon / colima / OrbStack, run with
# KAMAL_SSH_AUTH_SOCK="$SSH_AUTH_SOCK" to forward the host's own agent instead.
SSH_AUTH_SOURCE="${KAMAL_SSH_AUTH_SOCK:-/run/host-services/ssh-auth.sock}"

# Preflight (soft): before a setup/deploy, sanity-check the host so environmental
# traps — above all unresolvable container DNS — surface as a clear message HERE
# instead of a cryptic "target failed to become healthy" 30s into the deploy. It
# is read-only and NON-FATAL: it warns and proceeds (an operator who knows the
# host is fine is never blocked). Skip with PREFLIGHT=skip.
if [ "${PREFLIGHT:-}" != "skip" ] && { [ "${1:-}" = "setup" ] || [ "${1:-}" = "deploy" ]; }; then
  "$REPO_ROOT/infra/scripts/preflight-host.sh" || {
    echo "kamal-docker: preflight reported problems (see above) — proceeding anyway." >&2
    echo "kamal-docker: fix them (often: infra/scripts/bootstrap-host.sh) or set PREFLIGHT=skip." >&2
  }
fi

STATUS=0
docker run --rm -i $TTY_FLAG \
  -v "$REPO_ROOT:/workdir" -w /workdir/backend \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -v "$SSH_AUTH_SOURCE:/ssh-agent" -e SSH_AUTH_SOCK=/ssh-agent \
  -v "$HOME/.ssh/known_hosts:/root/.ssh/known_hosts:ro" \
  -e KAMAL_REGISTRY_USERNAME -e KAMAL_REGISTRY_PASSWORD \
  -e SECRET_KEY_BASE \
  -e DATABASE_PASSWORD -e NOMINATIM_PASSWORD \
  "$KAMAL_IMAGE" "$@" || STATUS=$?

# After a successful `setup`/`deploy`, ensure the self-hosted geo substrate
# (routing graph + vector tiles + geocoder OSM import) is provisioned on the host.
# This runs HERE, on the host machine — not as a Kamal hook — because the Kamal
# image has no bash/curl, and the build needs to drive Docker on the geo host over
# SSH. It is IDEMPOTENT: a no-op once the artifacts exist, so it adds only a few
# SSH checks to a routine deploy. The deploy scope is read from .kamal/geo.env /
# GEO_REGION_URL / GEO_COUNTRY (see infra/scripts/provision-geo-host.sh), kept
# independent of the local dev scope. Skip with GEO_PROVISION=skip.
SUBCMD="${1:-}"
if [ "$STATUS" -eq 0 ] && [ "${GEO_PROVISION:-}" != "skip" ] \
   && { [ "$SUBCMD" = "setup" ] || [ "$SUBCMD" = "deploy" ]; }; then
  echo "kamal-docker: ensuring geo substrate is provisioned (GEO_PROVISION=skip to bypass)…" >&2
  "$REPO_ROOT/infra/scripts/provision-geo-host.sh" || {
    echo "kamal-docker: geo provisioning did not complete — the app $SUBCMD itself succeeded." >&2
    echo "kamal-docker: re-run it later with: infra/scripts/provision-geo-host.sh" >&2
  }
fi

exit "$STATUS"
