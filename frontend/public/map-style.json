{
  "version": 8,
  "name": "flckd self-hosted basemap",
  "metadata": {
    "comment": "Self-hosted OpenMapTiles style. Vector tiles come from our own tileserver and glyphs from our own /fonts (vendored Noto Sans, see frontend/public/fonts) — no third-party/runtime requests (anonymity, FR-012a). /tiles and /fonts are proxied/served same-origin in dev and prod."
  },
  "glyphs": "/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "tiles": ["/tiles/{z}/{x}/{y}.mvt"],
      "minzoom": 0,
      "maxzoom": 14,
      "attribution": "© OpenMapTiles © OpenStreetMap contributors"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#080b12" }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "paint": { "fill-color": "#0e1520", "fill-opacity": 0.9 }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "paint": { "fill-color": "#121b28", "fill-opacity": 0.7 }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": { "fill-color": "#0d1f18", "fill-opacity": 0.8 }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": { "fill-color": "#071527" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": { "line-color": "#071527", "line-width": 1 }
    },
    {
      "id": "roads-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["!in", "class", "motorway", "trunk", "primary"],
      "paint": {
        "line-color": "#1c2440",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 14, 2]
      }
    },
    {
      "id": "roads-major",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary", "trunk"],
      "paint": {
        "line-color": "#27301c",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.8, 14, 4]
      }
    },
    {
      "id": "roads-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "motorway"],
      "paint": {
        "line-color": "#32200e",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 1, 14, 6]
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["<=", "admin_level", 4],
      "paint": { "line-color": "#1e2840", "line-dasharray": [2, 3], "line-width": 1 }
    },
    {
      "id": "road-labels",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "minzoom": 12,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": 11
      },
      "paint": { "text-color": "#2e3e5c", "text-halo-color": "#080b12", "text-halo-width": 1 }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["in", "class", "city", "town", "village"],
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 6, 11, 12, 16]
      },
      "paint": { "text-color": "#6378a0", "text-halo-color": "#080b12", "text-halo-width": 1.5 }
    }
  ]
}
